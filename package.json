{
  "name": "vue-fft-visualizer",
  "version": "0.2.0",
  "description": "A high-performance WebGL-based FFT spectrum visualizer component for Vue 3",
  "type": "module",
  "module": "./dist/vue-fft-visualizer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-fft-visualizer.js"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "import": "./dist/fft-wasm.js"
    },
    "./style.css": "./dist/vue-fft-visualizer.css"
  },
  "style": "./dist/vue-fft-visualizer.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release",
    "build": "vue-tsc && vite build",
    "build:playground": "vue-tsc && vite build --mode playground",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "prepack": "pnpm build:wasm && pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "typescript": "~5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vue": "^3.5.40",
    "vue-tsc": "^3.3.7"
  },
  "keywords": [
    "vue",
    "vue3",
    "fft",
    "spectrum",
    "visualizer",
    "audio",
    "webgl",
    "analyzer"
  ],
  "author": "Wouter Vernaillen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vernaillen/vue-fft-visualizer.git"
  },
  "bugs": {
    "url": "https://github.com/vernaillen/vue-fft-visualizer/issues"
  },
  "homepage": "https://github.com/vernaillen/vue-fft-visualizer#readme",
  "packageManager": "pnpm@11.15.0"
}
