{
  "name": "fft-visualizer-monorepo",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the FFT Visualizer family: a framework-agnostic WebGL spectrum-analyzer core and its framework wrappers",
  "scripts": {
    "dev": "pnpm --filter fft-visualizer-vue dev",
    "build": "pnpm -r build",
    "build:wasm": "pnpm --filter fft-visualizer-core build:wasm",
    "build:playground": "pnpm --filter fft-visualizer-core build && pnpm --filter fft-visualizer-vue build:playground",
    "preview": "pnpm --filter fft-visualizer-vue preview",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:node": "pnpm --filter fft-visualizer-core test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "rollup": "^4.62.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.10",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.40",
    "vue-tsc": "^3.3.7"
  },
  "packageManager": "pnpm@11.16.0"
}
